[Unit]
Description=Backplane MCP Server
After=network.target

[Service]
Type=simple
User=%%SERVICE_USER%%
WorkingDirectory=%%INSTALL_DIR%%
ExecStart=%%INSTALL_DIR%%/.venv/bin/python -m backplane.mcp
Restart=on-failure
RestartSec=5
EnvironmentFile=%%INSTALL_DIR%%/.env

[Install]
WantedBy=multi-user.target
