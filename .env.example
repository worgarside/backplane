OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault

# Home Assistant integration (optional — omit to skip HA MCP reload on startup)
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_MCP_ENTRY_ID=

# Public ChatGPT MCP endpoint (optional — only required for python -m backplane.mcp.public)
MCP_PUBLIC_BASE_URL=https://backplane-mcp.example.com
MCP_OAUTH_ISSUER=https://auth.example.com/application/o/backplane-mcp/
MCP_OAUTH_AUTHORIZATION_ENDPOINT=https://auth.example.com/application/o/authorize/
MCP_OAUTH_TOKEN_ENDPOINT=https://auth.example.com/application/o/token/
MCP_OAUTH_JWKS_URI=https://auth.example.com/application/o/backplane-mcp/jwks/
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
MCP_OAUTH_AUDIENCE=
