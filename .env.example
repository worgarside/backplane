OBSIDIAN_VAULT_PATH=/path/to/obsidian/vault

# Home Assistant integration (optional — omit to skip HA MCP reload on startup)
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=
HOME_ASSISTANT_MCP_ENTRY_ID=

# Home Assistant MCP upstream (optional — proxy HA MCP add-on through Backplane)
# BACKPLANE_HA_MCP_ENABLED=false
# BACKPLANE_HA_MCP_URL=http://10.0.0.x:9583/<secret-path>
# BACKPLANE_HA_MCP_NAMESPACE=ha
# BACKPLANE_HA_MCP_CONNECT_TIMEOUT_SECONDS=5

# Public MCP OAuth via Authentik (required before INSTALL_PUBLIC_MCP=true)
# Configure these, then run: sudo INSTALL_PUBLIC_MCP=true bash deploy/setup.sh
# See deploy/authentik-backplane-mcp.env.example for Authentik provider setup.
# MCP_PUBLIC_BASE_URL=https://backplane-mcp.example.com
# MCP_OIDC_CONFIG_URL=https://auth.example.com/application/o/backplane-mcp/.well-known/openid-configuration
# MCP_OIDC_CLIENT_ID=
# MCP_OIDC_CLIENT_SECRET=
